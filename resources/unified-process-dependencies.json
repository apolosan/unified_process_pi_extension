{
  "packageName": "@apolosan/unified-process",
  "install": {
    "preferred": "pi install npm:@apolosan/unified-process",
    "alternative": "pi install git:github.com/apolosan/unified_process_pi_extension"
  },
  "mcpServers": [
    {
      "id": "design-patterns",
      "level": "recommended",
      "source": "https://github.com/apolosan/design_patterns_mcp",
      "install": [
        "git clone https://github.com/apolosan/design_patterns_mcp.git .up-tools/design_patterns_mcp",
        "cd .up-tools/design_patterns_mcp && bun install && bun run db:setup"
      ],
      "config": {
        "command": "node",
        "args": [
          "dist/src/mcp-server.js"
        ],
        "cwd": ".up-tools/design_patterns_mcp",
        "env": {
          "LOG_LEVEL": "info",
          "DATABASE_PATH": "./data/design-patterns.db",
          "ENABLE_HYBRID_SEARCH": "true",
          "ENABLE_GRAPH_AUGMENTATION": "true",
          "EMBEDDING_COMPRESSION": "true",
          "ENABLE_FUZZY_LOGIC": "true",
          "ENABLE_TELEMETRY": "true",
          "ENABLE_MULTI_LEVEL_CACHE": "true"
        }
      }
    },
    {
      "id": "shadcn",
      "level": "recommended",
      "command": "npx -y shadcn@latest mcp"
    },
    {
      "id": "radix-mcp-server",
      "level": "recommended",
      "command": "npx -y @gianpieropuleo/radix-mcp-server@latest"
    },
    {
      "id": "flyonui",
      "level": "recommended",
      "command": "npx -y flyonui-mcp"
    }
  ],
  "companionSkills": [
    "context7",
    "brave-search",
    "web-search",
    "web-fetch"
  ],
  "coreCliTools": [
    "npm",
    "npx",
    "mmdc",
    "docker",
    "docker-compose",
    "git",
    "bun",
    "node"
  ],
  "conditionalCliTools": [
    "jest",
    "pytest",
    "playwright",
    "cypress",
    "testcontainers",
    "wiremock",
    "pact",
    "storybook",
    "selenium",
    "appium",
    "detox",
    "k6",
    "locust",
    "jmeter",
    "gatling",
    "owasp-zap",
    "semgrep",
    "sonarqube",
    "codeql",
    "snyk",
    "trivy",
    "axe-core",
    "lighthouse",
    "pa11y",
    "stryker",
    "mutmut",
    "pitest",
    "fast-check",
    "hypothesis",
    "quickcheck",
    "libfuzzer",
    "afl++",
    "oss-fuzz"
  ]
}
